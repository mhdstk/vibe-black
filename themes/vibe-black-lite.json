  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5E9E4D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#D4A07A"
      }
    },
    {
      "name": "String Escape Characters",
      "scope": [
        "constant.character.escape",
        "string source"
      ],
      "settings": {
        "foreground": "#C8AE6A"
      }
    },
    {
      "name": "Keywords & Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.delete"
      ],
      "settings": {
        "foreground": "#5BA0D0"
      }
    },
    {
      "name": "Import / Export Keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#B880C0"
      }
    },
    {
      "name": "Storage & Types",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5BA0D0"
      }
    },
    {
      "name": "Language Constants",
      "scope": [
        "constant.language",
        "variable.language.this",
        "variable.language.super",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#5BA0D0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "support.variable"
      ],
      "settings": {
        "foreground": "#8DCBF4"
      }
    },
    {
      "name": "Object Keys & Properties",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#8DCBF4"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#8DCBF4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants & Enum Members",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#42B4F4"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#D8D490"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#A8C898"
      }
    },
    {
      "name": "Punctuation & Operators",
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#C0C0C0"
      }
    },
    {
      "name": "Classes & Type Names",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#42C0A8"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#42C0A8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Built-in Types",
      "scope": [
        "support.type",
        "entity.name.type.parameter",
        "entity.name.type.primitive"
      ],
      "settings": {
        "foreground": "#42C0A8"
      }
    },
    {
      "name": "Namespace & Module Names",
      "scope": [
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": {
        "foreground": "#42C0A8"
      }
    },
    {
      "name": "Decorators & Annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator punctuation.decorator",
        "tag.decorator entity.name.tag"
      ],
      "settings": {
        "foreground": "#B880C0"
      }
    },
    {
      "name": "HTML / JSX Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#E87070"
      }
    },
    {
      "name": "HTML / JSX Attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8DCBF4"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "string.regexp keyword.operator"
      ],
      "settings": {
        "foreground": "#C86060"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.selector",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.class.css",
        "meta.selector"
      ],
      "settings": {
        "foreground": "#C8A860"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.vendored.property-name",
        "support.type.property-name.css",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#8DCBF4"
      }
    },
    {
      "name": "CSS Values & Units",
      "scope": [
        "support.constant.property-value",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#D4A07A"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#42C0A8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#D8D490",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#D4A07A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Inline Code",
      "scope": [
        "markup.inline.raw.string",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#D4A07A"
      }
    },
    {
      "name": "Markdown Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#5BA0D0"
      }
    },
    {
      "name": "Invalid & Deprecated",
      "scope": [
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#E84040"
      }
    }
  ]
}